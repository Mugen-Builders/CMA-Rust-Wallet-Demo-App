# Compose env — consumed by docker compose for ${...} substitution.
# Endpoints use the Docker host-gateway: the node containers dial the anvil that
# ./run_devnet.sh runs on the host (bound to 0.0.0.0).
AUTH_KIND=private_key
BLOCKCHAIN_ID=31337
# Anvil account 0 private key (this account is also the app guardian — see withdrawal.json)
CARTESI_AUTH_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
BLOCKCHAIN_HTTP_ENDPOINT=http://host.docker.internal:8545
BLOCKCHAIN_WS_ENDPOINT=ws://host.docker.internal:8545
# Accounts-drive withdrawal output builder for the bundled devnet's TestFungibleToken.
WITHDRAWAL_OUTPUT_BUILDER_ADDRESS=0x0745787835A019cd4dae8EDB541Fbc0647793d63
