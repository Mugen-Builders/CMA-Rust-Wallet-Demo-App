# Host-side env — `source host.env` before running cartesi-rollups-cli on the host.
# Endpoints use localhost (the compose exposes 8545 and 5432 to the host).
export CARTESI_BLOCKCHAIN_HTTP_ENDPOINT=http://localhost:8545
export CARTESI_BLOCKCHAIN_ID=31337
export CARTESI_DATABASE_CONNECTION=postgres://postgres:password@localhost:5432/rollupsdb?sslmode=disable
export CARTESI_AUTH_KIND=private_key
export CARTESI_AUTH_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80
# v3 contract addresses (must match the devnet)
export CARTESI_CONTRACTS_INPUT_BOX_ADDRESS=0x346B3df038FE9f8380071eC6514D5a83aD143939
export CARTESI_CONTRACTS_APPLICATION_FACTORY_ADDRESS=0xC549F89cF1ca43eDDECC64Ac2208F4b283B1c483
export CARTESI_CONTRACTS_SELF_HOSTED_APPLICATION_FACTORY_ADDRESS=0x6145C5996a71a379E030aEb0440df79D60833418
export CARTESI_CONTRACTS_AUTHORITY_FACTORY_ADDRESS=0x3C1FE01c542a88A523FF6847eD1E26176c8C4ED0
export CARTESI_CONTRACTS_QUORUM_FACTORY_ADDRESS=0x1f94009389F408B8D0ADfFcF8BBDCe5552BaCa5F
